# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cinerecops
MLFLOW_MODEL_NAME=cinerecops-recommender

# Model Registry
MODEL_STAGE=Production   # Staging | Production | Archived

# Data paths
DATA_DIR=data/
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Monitoring
PROMETHEUS_PORT=8001

